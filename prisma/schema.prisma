generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  LIDER
  SECRETARIA
}

enum MemberStatus {
  ATIVO
  INATIVO
  VISITANTE
  DISCIPULADO
}

enum InviteStatus {
  PENDENTE
  FEITO
  CONFIRMADO
  AUSENTE
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String
  role        Role      @default(LIDER)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  sentHistories ContactHistory[]
  tasks         Task[]
}

model Group {
  id           String   @id @default(uuid())
  name         String
  description  String?
  liderId      String?
  address      String?
  neighborhood String?
  mapUrl       String?
  contactPhone String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  members Member[]
}

model Member {
  id           String       @id @default(uuid())
  name         String
  birthDate    DateTime?
  phone        String? // WhatsApp (+55...)
  email        String?
  address      String?
  city         String?
  neighborhood String?
  status       MemberStatus @default(VISITANTE)
  inviteStatus InviteStatus @default(PENDENTE)
  groupId      String?
  joinDate     DateTime?
  isBaptized   Boolean      @default(false)
  baptizeDate  DateTime?
  notes        String?
  source       String? // Como conheceu (ex: Instagram, Amigo: Joao)
  photoUrl     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  isDeleted    Boolean      @default(false)
  deletedAt    DateTime?

  // Relations
  group         Group?           @relation(fields: [groupId], references: [id])
  histories     ContactHistory[]
  attendances   Attendance[]
  audits        MemberAudit[]
  tasks         Task[]
  ministries    MinistryMember[]
  scheduleSlots ScheduleSlot[]
  @@index([status])
  @@index([phone])
}

model MemberAudit {
  id        String   @id @default(uuid())
  memberId  String
  userName  String // Nome de quem editou (via LocalStorage)
  action    String   @db.Text
  createdAt DateTime @default(now())

  // Relations
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Event {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  time        String? // HH:MM
  type        String   @default("OUTRO") // CULTO, CELULA, REUNIAO, OUTRO
  location    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  attendances   Attendance[]
  scheduleSlots ScheduleSlot[]
  @@index([date])
}

model Attendance {
  id        String   @id @default(uuid())
  eventId   String
  memberId  String
  isPresent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
}

model Template {
  id        String   @id @default(uuid())
  name      String
  category  String
  content   String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  histories ContactHistory[]
}

model ContactHistory {
  id         String   @id @default(uuid())
  userId     String // Whoever sent the message
  memberId   String // Who received
  templateId String? // Optional if it was a free text message
  customText String?  @db.Text
  sentAt     DateTime @default(now())
  notes      String?

  // Relations
  user     User      @relation(fields: [userId], references: [id])
  member   Member    @relation(fields: [memberId], references: [id])
  template Template? @relation(fields: [templateId], references: [id])
}

model Settings {
  id                String   @id @default("global")
  inactivityDays    Int      @default(20)
  defaultChurchName String   @default("Lounge For You")
  leaders           String[] @default([]) // Array de ResponsÃ¡veis
  areas             String[] @default([]) // Array de Ãreas de Escolha
  primaryColor      String?  @default("#6366f1")
  themeMode         String?  @default("system")
  webhookUrl        String?
  updatedAt         DateTime @updatedAt
}

enum TaskType {
  BIRTHDAY
  INACTIVITY
  FOLLOW_UP
  OTHER
}

enum TaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?    @db.Text
  type        TaskType   @default(OTHER)
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  memberId    String?
  assignedTo  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  member Member? @relation(fields: [memberId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  @@index([type])
  @@index([status])
}

model HubSettings {
  id               String   @id @default("global")
  title            String   @default("Bem-vindo!")
  heroSubtitle     String   @default("Estamos muito felizes em ter voce aqui.")
  mission          String   @default("Preencha a Missao da Igreja nas configuracoes.") @db.Text
  vision           String   @default("Preencha a Visao da Igreja nas configuracoes.") @db.Text
  values           String   @default("Preencha os Valores nas configuracoes.") @db.Text
  hhsInfo          String   @default("Informacoes sobre as Celulas / HHs.") @db.Text
  whatsappGroupUrl String?
  instagramUrl     String?
  cultoSchedule    String?
  celulaSchedule   String?
  address          String?
  mapsEmbedUrl     String?
  galleryUrls      String[] @default([])
  youtubeUrl       String?
  updatedAt        DateTime @updatedAt
}

enum MinistryRole {
  VOLUNTARIO
  LIDER_MINISTERIO
}

enum SlotStatus {
  PENDENTE
  CONFIRMADO
  RECUSADO
}

model Ministry {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String   @default("#6366f1")
  icon        String   @default("music")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   MinistryMember[]
  schedules ScheduleSlot[]
}

model MinistryMember {
  id         String       @id @default(uuid())
  ministryId String
  memberId   String
  role       MinistryRole @default(VOLUNTARIO)
  instrument String?
  position   String?
  createdAt  DateTime     @default(now())

  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([ministryId, memberId])
}

model ScheduleSlot {
  id         String     @id @default(uuid())
  ministryId String
  eventId    String
  memberId   String
  status     SlotStatus @default(PENDENTE)
  position   String?
  notes      String?
  createdAt  DateTime   @default(now())

  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([ministryId, eventId, memberId])
  @@index([eventId])
}
